{
  "expo": {
    "name": "Travel_client",
    "slug": "Travel_client",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "travelclient",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "981ab422-bc83-4e15-95c2-b8c5310208f4"
      }
    },
    "android": {
      "package": "com.maddalahemanth.triparchitectai"
    }
  }
}
